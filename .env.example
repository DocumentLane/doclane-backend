PORT=3000
TRUST_PROXY=false
DATABASE_URL="postgresql://doclane:doclane@localhost:5432/doclane?schema=public"

OIDC_ISSUER_URL="https://issuer.example.com"
OIDC_CLIENT_ID="doclane"
OIDC_CLIENT_SECRET="change-me"
OIDC_REDIRECT_URI="http://localhost:3000/auth/oidc/callback"
OIDC_SCOPES="openid email profile"

JWT_ACCESS_SECRET="replace-with-at-least-32-characters"
JWT_REFRESH_SECRET="replace-with-at-least-32-characters-refresh"
JWT_ACCESS_TOKEN_EXPIRES_IN_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRES_IN_SECONDS=1209600

REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0

S3_REGION="us-east-1"
S3_BUCKET="doclane"
S3_ACCESS_KEY_ID="change-me"
S3_SECRET_ACCESS_KEY="change-me"
S3_ENDPOINT="http://localhost:9000"
S3_FORCE_PATH_STYLE=true

PDF_OCR_LANGUAGE="eng"
PDF_OCR_DPI=300
PDF_OCR_PSM=6
PDF_OCR_PDF_OUTPUT_ENABLED=true
